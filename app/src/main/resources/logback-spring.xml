<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <property name="CONSOLE_PATTERN"
            value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%thread] %logger{36} - [%X{correlationId}] %msg%n"/>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${CONSOLE_PATTERN}</pattern>
    </encoder>
  </appender>

  <!-- Default: production-ish -->
  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>

  <!-- Local profile: noisier -->
  <springProfile name="local">
    <root level="DEBUG"/>
  </springProfile>

  <!-- Test profile: quieter -->
  <springProfile name="test">
    <root level="WARN"/>
  </springProfile>

</configuration>
